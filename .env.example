# fable_watch secrets + personal targets.
# Copy this to .env (gitignored) and fill in. Blank/removed lines are skipped.
# Values here override config.toml. Nothing in this example is personal data.

# --- Email (optional) -------------------------------------------------------
# Gmail needs an App Password (Google Account -> Security -> 2-Step Verification
# -> App passwords), NOT your normal account password.
FABLE_WATCH_EMAIL_TO=
FABLE_WATCH_SMTP_USERNAME=
FABLE_WATCH_EMAIL_FROM=
FABLE_WATCH_SMTP_PASSWORD=

# --- ntfy phone push (optional) --------------------------------------------
# Pick a long, unguessable topic name -- anyone who knows it can read your
# alerts. Install the ntfy app (ntfy.sh) and subscribe to the same topic.
FABLE_WATCH_NTFY_TOPIC=
# FABLE_WATCH_NTFY_SERVER=https://ntfy.sh

# --- Watch overrides (optional) --------------------------------------------
# FABLE_WATCH_MODEL=claude-fable-5
# FABLE_WATCH_INTERVAL=300
